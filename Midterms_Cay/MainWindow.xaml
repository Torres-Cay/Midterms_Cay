<Window x:Class="Midterms_Cay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Midterms_Cay"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <TextBlock Text="Shopping Cart System" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

        <DataGrid x:Name="myDataGrid" Margin="10,52,400,185" ItemsSource="{Binding Products}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <DataGrid x:Name="myDataGrid2" Margin="405,52,5,185" ItemsSource="{Binding AddedCart}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,250,0,0" VerticalAlignment="Top" Width="800" Height="161">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="ID" HorizontalAlignment="Left"  FontSize="12"/>
                <TextBox x:Name="IdTextBox" Height="20" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Name" HorizontalAlignment="Left" FontSize="12"/>
                <TextBox x:Name="NameTextBox" Height="20" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Description" HorizontalAlignment="Left"  FontSize="12"/>
                <TextBox x:Name="TitleTextBox" Height="20" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Price" HorizontalAlignment="Left" FontSize="12"/>
                <TextBox x:Name="SalaryTextBox" Height="20" Width="100"/>
            </StackPanel>
            <WrapPanel>
                <Button x:Name="AddButton" Content="Add" Click="AddBtn_Click" Height="20" Width="50" Margin="10,126,0,0"/>
            </WrapPanel>
            <WrapPanel>
                <Button x:Name="RemoveButton" Content="Remove Items" Click="RemoveBtn_Click" Height="20" Width="50" Margin="10,126,0,0" />
            </WrapPanel>
            <WrapPanel>
                <Button x:Name="UpdateButton" Content="Add Item" Click="UpdateBtn_Click" Height="20" Margin="10,126,0,0" />
            </WrapPanel>
            <WrapPanel>
                <Button x:Name="AddtoCartBtn" Content="Add To Cart" Click="AddtoCartBtn_Click" Height="20"  Margin="10,126,0,0" />
            </WrapPanel>
            <WrapPanel>
                <Button x:Name="ClearButton" Content="Clear" Click="ClearBtn_Click" Height="20" Width="50" Margin="10,126,0,0" />
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
