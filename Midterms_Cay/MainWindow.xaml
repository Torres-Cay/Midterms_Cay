<Window x:Class="Midterms_Cay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Midterms_Cay"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="343*"/>
            <ColumnDefinition Width="57*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Shopping Cart System" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left" Margin="296,0,0,0" Width="208"/>
        <TextBlock Text="Available Products Section" FontSize="17" FontWeight="Bold" Margin="95,27,126,383" />
        <TextBlock Text="Shopping Cart Section" FontSize="17" FontWeight="Bold" Margin="76,25,38,382" Grid.Column="1" />

        <DataGrid x:Name="myDataGrid" Margin="10,52,288,185" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid x:Name="myDataGrid2" Margin="405,52,5,185" ItemsSource="{Binding AddedCart}" AutoGenerateColumns="False" Grid.ColumnSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,157,0,0" VerticalAlignment="Top" Height="146" Width="660" Grid.ColumnSpan="2" >
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Product ID" HorizontalAlignment="Left" FontSize="12"/>
                <TextBox x:Name="IdTextBox" Height="20" Width="90"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Product Name" HorizontalAlignment="Left" FontSize="12"/>
                <TextBox x:Name="NameTextBox" Height="20" Width="110"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Description" HorizontalAlignment="Left" FontSize="12"/>
                <TextBox x:Name="TitleTextBox" Height="20" Width="110"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Price" HorizontalAlignment="Left" FontSize="12"/>
                <TextBox x:Name="SalaryTextBox" Height="20" Width="90"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Search" HorizontalAlignment="Left" FontSize="12" />
                <TextBox x:Name="SearchTextBox" Height="20" Width="120" TextChanged="SearchTextBox_TextChanged"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="80,210,10,0" Grid.ColumnSpan="2" >
            <StackPanel>
                <Button x:Name="AddButton" Content="Add" Click="AddBtn_Click" Height="20" Width="50" Margin="10,126,0,0"/>
            </StackPanel>
            <StackPanel>
                <Button x:Name="RemoveButton" Content="Remove Items" Click="RemoveBtn_Click" Height="20" Width="90" Margin="10,126,0,0" />
            </StackPanel>
            <StackPanel>
                <Button x:Name="UpdateButton" Content="Update Item" Click="UpdateBtn_Click" Height="20" Width="80" Margin="10,126,0,0" />
            </StackPanel>
            <StackPanel>
                <Button x:Name="AddtoCartBtn" Content="Add To Cart" Click="AddtoCartBtn_Click" Height="20" Margin="10,126,0,0" />
            </StackPanel>
            <StackPanel>
                <Button x:Name="RemovefromCartBtn" Content="Remove From Cart" Click="RemovefromCartBtn_Click" Height="20" Margin="10,126,0,0" />
            </StackPanel>
            <StackPanel>
                <Button x:Name="ClearButton" Content="Clear" Click="ClearBtn_Click" Height="20" Width="50" Margin="10,126,0,0" />
            </StackPanel>
            <StackPanel>
                <ComboBox Height="20" Width="130" Margin="10,126,0,0" SelectionChanged="Sort_SelectionChanged" x:Name="Sort" SelectedIndex="0">
                    <ComboBoxItem Content="No Sort"/>
                    <ComboBoxItem Content="A-Z"/>
                    <ComboBoxItem Content="Z-A"/>
                    <ComboBoxItem Content="Price(Low - High)"/>
                    <ComboBoxItem Content="Price(High - Low)"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>